{
    "type": "package",
    "name": "elm-cardano/cbor",
    "summary": "CBOR (RFC 8949) encoder and decoder with lossless round-tripping",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Cbor",
        "Cbor.Decode",
        "Cbor.Encode"
    ],
    "elm-version": "0.19.1 <= v < 0.20.0",
    "dependencies": {
        "elm/bytes": "1.0.8 <= v < 2.0.0",
        "elm/core": "1.0.5 <= v < 2.0.0",
        "elm-cardano/bytes-decoder": "1.1.0 <= v < 2.0.0",
        "elm-cardano/float16": "1.0.0 <= v < 2.0.0",
        "elm-cardano/x-bytes": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.2.1 <= v < 3.0.0"
    }
}
